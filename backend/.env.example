# 服务器配置
PORT=60000
HOST=127.0.0.1
DATA_FILE=data/app.db
STATIC_DIR=../frontend/dist

# JWT 配置（生产环境请修改）
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d

# AI Provider 配置
# 可选值: mock (模拟), http (通用 HTTP)
# 具体 AI 厂商和模型请在设置页面 (Settings → Model Connection) 配置
AI_PROVIDER=http

# HTTP Provider 端点（可选，如需从环境变量配置）
# AI_API_KEY=your-api-key-here
# AI_TEXT_ENDPOINT=https://api.example.com/v1/chat/completions
# AI_IMAGE_ENDPOINT=https://api.example.com/v1/images/generations
# AI_VIDEO_ENDPOINT=https://api.example.com/v1/videos/generations
# AI_AUDIO_ENDPOINT=https://api.example.com/v1/audio/synthesis

# 请求配置
AI_TIMEOUT_MS=45000
AI_AUTH_HEADER=Authorization
AI_MAX_RETRIES=2
AI_RETRY_DELAY_MS=600

# 视频处理配置
VIDEO_MAX_CONCURRENT=2
FFMPEG_BIN=ffmpeg
VIDEO_MERGE_OUTPUT_DIR=data/video-merges
VIDEO_MERGE_ENGINE=ffmpeg

# 队列配置（可选）
# QUEUE_DRIVER=internal
# QUEUE_BACKEND=lease
# QUEUE_REDIS_URL=redis://127.0.0.1:6379
